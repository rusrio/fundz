generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum AgentStatus {
  ACTIVE
  DISABLED
}

enum IntentStatus {
  RECEIVED
  POLICY_APPROVED
  POLICY_REJECTED
  EXECUTING
  EXECUTED
  FAILED
}

enum ExecutionStatus {
  PENDING
  SUBMITTED
  CONFIRMED
  FAILED
}

enum AgentCredentialStatus {
  ACTIVE
  REVOKED
}

enum RiskEventStatus {
  TRIGGERED
  RESOLVED
  FAILED
}

enum PayoutStatus {
  PENDING
  SUBMITTED
  CONFIRMED
  FAILED
}

model Agent {
  id           String   @id @default(uuid())
  name         String
  ownerAddress String   @unique
  safeAddress  String?
  status       AgentStatus @default(ACTIVE)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  policy     Policy?
  riskPolicy RiskPolicy?
  credentials AgentCredential[]
  intents    Intent[]
  executions Execution[]
  riskSnapshots RiskSnapshot[]
  riskEvents RiskEvent[]
  payouts Payout[]
}

model RiskPolicy {
  id                  String   @id @default(uuid())
  agentId             String   @unique
  enabled             Boolean  @default(false)
  chainId             Int      @default(1)
  baseAsset           String
  riskAsset           String
  protocolCapital     String   @default("0")
  agentLossMargin     String   @default("0")
  accessFee           String   @default("0")
  protectedValue      String   @default("0")
  initialValue        String
  maxLoss             String
  minValue            String
  pollSeconds         Int      @default(15)
  emergencySlippageBps Int     @default(100)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model RiskSnapshot {
  id          String   @id @default(uuid())
  agentId     String
  safeAddress String
  baseAsset   String
  riskAsset   String
  baseBalance String
  riskBalance String
  riskValue   String
  totalValue  String
  minValue    String
  breached    Boolean
  createdAt   DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId, createdAt])
  @@index([breached])
}

model RiskEvent {
  id             String          @id @default(uuid())
  agentId        String
  snapshotId     String?
  status         RiskEventStatus @default(TRIGGERED)
  reason         String
  emergencyTxHash String?
  errorMessage   String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId, createdAt])
  @@index([status])
}

model Payout {
  id           String       @id @default(uuid())
  agentId      String
  safeAddress  String
  recipient    String
  baseAsset    String
  amount       String
  profit       String
  shareBps     Int
  status       PayoutStatus @default(PENDING)
  txHash       String?
  errorMessage String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId, createdAt])
  @@index([status])
}

model AgentCredential {
  id         String                @id @default(uuid())
  agentId    String
  tokenHash  String                @unique
  label      String?
  status     AgentCredentialStatus @default(ACTIVE)
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId, status])
}

model Policy {
  id                    String   @id @default(uuid())
  agentId               String   @unique
  chainId               Int
  allowedTokenAddresses String
  maxAmountPerOperation String
  cooldownSeconds       Int
  dailyLimit            String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model Intent {
  id             String       @id @default(uuid())
  agentId        String
  nonce          String
  action         String
  chainId        Int
  tokenIn        String
  tokenOut       String
  amountIn       String
  maxSlippageBps Int
  deadline       DateTime
  signature      String
  status         IntentStatus @default(RECEIVED)
  rejectionReason String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  agent      Agent       @relation(fields: [agentId], references: [id], onDelete: Cascade)
  evaluation Evaluation?
  execution  Execution?

  @@unique([agentId, nonce])
  @@index([agentId, createdAt])
  @@index([status])
}

model Evaluation {
  id          String   @id @default(uuid())
  intentId    String   @unique
  approved    Boolean
  reasons     String
  evaluatedAt DateTime @default(now())

  intent Intent @relation(fields: [intentId], references: [id], onDelete: Cascade)
}

model Execution {
  id           String          @id @default(uuid())
  intentId     String          @unique
  agentId      String
  safeAddress  String
  adapter      String
  status       ExecutionStatus @default(PENDING)
  txHash       String?
  amountIn     String
  amountOut    String?
  errorMessage String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  intent Intent @relation(fields: [intentId], references: [id], onDelete: Cascade)
  agent  Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId, createdAt])
  @@index([status])
}
