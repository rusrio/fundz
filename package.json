{
  "name": "fundz",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "dev": "pnpm --parallel -r dev",
    "db:generate": "pnpm --filter @fundz/db db:generate",
    "db:push": "pnpm --filter @fundz/db db:push",
    "db:seed": "pnpm --filter @fundz/db db:seed"
  },
  "devDependencies": {
    "@types/node": "^20.17.30",
    "typescript": "^5.8.3"
  }
}
